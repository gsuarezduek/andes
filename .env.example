# Andes — variables de entorno
# Copiar a `.env` y completar. `.env` está en .gitignore (nunca commitear secretos).
# Las variables están agrupadas por la fase que las introduce (ver PROYECTO-ANDES.md §10).

# --- Base de datos (Fase 0/1) ---
# PostgreSQL en Railway.
DATABASE_URL="postgresql://user:password@host:5432/andes?schema=public"

# --- App (Fase 0) ---
NEXT_PUBLIC_APP_URL="https://andes.mdzrentacar.com"

# --- Autenticación (Fase 1) ---
# Generar con: openssl rand -base64 32
AUTH_SECRET=""
# URL pública canónica que usa Auth.js para armar redirects. IMPRESCINDIBLE en
# producción detrás del proxy de Railway (si falta, redirige a localhost:PORT).
# En local no hace falta.
AUTH_URL="https://andes.mdzrentacar.com"
# Login con Google (opcional). Crear credenciales OAuth 2.0 en Google Cloud
# Console → "IDs de cliente de OAuth" tipo "Aplicación web". Authorized redirect
# URI: https://andes.mdzrentacar.com/api/auth/callback/google (y en local
# http://localhost:3000/api/auth/callback/google). Auth.js detecta estas dos
# variables automáticamente. Solo entra quien ya existe y está activo en `users`
# (el alta la sigue haciendo el admin); Google no da de alta usuarios.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- WordPress / VikRentCar — Fase 5 (sincronización de reservas) ---
# Dos transportes intercambiables. En producción se usa REST (mu-plugin);
# el MySQL directo queda solo para pruebas locales contra datos reales.
#
# Transporte REST (producción, recomendado): mu-plugin andes-sync en WordPress.
# Ver wordpress-plugin/andes-sync.php. El token debe coincidir con el definido
# en wp-config.php (define('ANDES_SYNC_TOKEN', '...')).
WP_REST_URL="https://mdzrentacar.com/wp-json/andes/v1"
WP_REST_TOKEN=""

# Transporte MySQL directo (solo pruebas locales; requiere "Remote MySQL" abierto).
# Dejar vacío en producción. Si WP_REST_URL está seteado, tiene prioridad.
WP_MYSQL_HOST=""
WP_MYSQL_PORT="3306"
WP_MYSQL_DATABASE=""
WP_MYSQL_USER=""
WP_MYSQL_PASSWORD=""

# Secreto compartido que protege POST /api/sync (lo usa el cron de Railway).
CRON_SECRET=""

# Ventana de sincronización (opcional; defaults razonables para el volumen actual).
SYNC_WINDOW_DAYS_BACK="2"
# Días para adelante que trae el sync (las reservas entran con meses de anticipación).
SYNC_WINDOW_DAYS_FORWARD="120"
# Traer reservas sin confirmar (standby): por defecto SÍ (se muestran en naranja).
# Poné "false" para excluirlas del sync.
SYNC_INCLUDE_STANDBY="true"

# --- Cloudflare R2 — almacenamiento de fotos, videos, firmas y PDFs (Fase 2) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="andes-media"

# --- Email transaccional — Resend (Fase 2) ---
RESEND_API_KEY=""
EMAIL_FROM="entregas@mdzrentacar.com"
ADMIN_EMAIL=""
