// Andes — Prisma schema
//
// Modelo de datos completo (Fase 1), según PROYECTO-ANDES.md §6 y el
// descubrimiento de VikRentCar (docs/wordpress-mapping.md).
//
// Convenciones: modelos en PascalCase (inglés), tablas/columnas en snake_case
// vía @@map/@map. Todo cambio de esquema va por migración (`prisma migrate dev`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  admin
  empleado
}

enum VehicleStatus {
  available
  rented
  out_of_service
}

enum RentalOrigin {
  vikrentcar
  manual
}

enum RentalStatus {
  reserved
  active
  finished
  cancelled
}

/// Idioma de cara al cliente (acta, emails, firma). Ver src/lib/i18n.
enum Language {
  es
  en
}

enum InspectionType {
  handover // entrega
  return_  // devolución (`return` es palabra reservada en algunos contextos)
}

enum MediaType {
  photo
  video
}

/// Vistas del croquis donde se marca un daño.
enum DamageView {
  top
  front
  rear
  left
  right
  interior
}

enum MaintenanceType {
  service
  repair
  expense
  note
}

/// Tipo de documento del cliente capturado en la entrega.
enum DocumentKind {
  license  // licencia de conducir
  dni      // documento de identidad
  passport // pasaporte
}

enum SyncResult {
  success
  partial
  error
}

/// Estado de un pedido de firma remota (el cliente firma en su teléfono).
enum SignatureRequestStatus {
  pending
  signed
  expired
  cancelled
}

// ---------------------------------------------------------------------------
// Usuarios y autenticación
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(empleado)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  inspections       Inspection[]
  rentalDocuments   RentalDocument[]
  signatureRequests SignatureRequest[]
  reportedDamages   Damage[]           @relation("DamageReporter")
  repairedDamages   Damage[]           @relation("DamageRepairer")

  @@map("users")
}

// ---------------------------------------------------------------------------
// Flota
// ---------------------------------------------------------------------------

model Vehicle {
  id            String        @id @default(cuid())
  plate         String        @unique // patente
  brand         String // marca
  model         String // modelo
  year          Int?
  color         String?
  currentKm     Int           @default(0) @map("current_km")
  status        VehicleStatus @default(available)
  nextServiceKm Int?          @map("next_service_km")
  // Cantidad de líneas/octavos del tanque de este auto (4–16, default 8). El
  // nivel de nafta de cada inspección se mide 0..fuelLevels. Configurable por
  // unidad: distintos autos tienen distinta granularidad de aguja.
  fuelLevels    Int           @default(8) @map("fuel_levels")
  // Intervalo de service en km. Al registrar un service, el próximo se
  // reprograma a (km del service + intervalo). Alimenta las alertas.
  serviceIntervalKm Int? @map("service_interval_km")
  photoUrl      String?       @map("photo_url")
  notes         String?

  // Tarifa de referencia por 1 día (traída de VikRentCar: dispcost days=1 ×
  // ajuste de temporada vigente). La refresca la sincronización; varía según la
  // fecha/temporada. Ver docs/wordpress-mapping.md y src/lib/sync.
  dailyRate          Decimal?  @map("daily_rate") @db.Decimal(12, 2)
  dailyRateUpdatedAt DateTime? @map("daily_rate_updated_at")

  // Orden manual en la vista Calendario (menor = más arriba). Refleja la lista
  // "del más caro al más económico" de la agenda; se carga a mano por unidad.
  // Los autos sin orden (null) quedan al final, ordenados por marca/modelo.
  sortOrder Int? @map("sort_order")

  // Archivado: baja de la flota operativa sin borrar la ficha (histórico,
  // actas y daños se conservan — evidencia inmutable). Ortogonal a `status`:
  // un auto puede archivarse recién cuando deja de estar `rented`. Los autos
  // archivados se excluyen de dashboard, listados operativos, QR y pickers,
  // pero su perfil sigue accesible. Ver docs: baja de auto en VikRentCar.
  archivedAt DateTime? @map("archived_at")

  // Mapeo a la unidad de VikRentCar (idcar, carindex). Ver docs/wordpress-mapping.md.
  wpCarId    Int? @map("wp_car_id")
  wpCarIndex Int? @map("wp_car_index")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rentals         Rental[]
  inspections     Inspection[]
  damages         Damage[]
  maintenanceLogs MaintenanceLog[]

  @@unique([wpCarId, wpCarIndex])
  @@map("vehicles")
}

// ---------------------------------------------------------------------------
// Alquileres
// ---------------------------------------------------------------------------

model Rental {
  id String @id @default(cuid())

  // Nullable a propósito: una reserva de VikRentCar puede llegar sin unidad
  // asignada (carindex NULL) → "reserva sin vehículo asignado".
  vehicleId String?  @map("vehicle_id")
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  // Datos del cliente (denormalizados: el alquiler es la fuente de verdad del
  // contrato, independiente de cambios posteriores en VikRentCar).
  clientName      String    @map("client_name")
  clientEmail     String?   @map("client_email")
  clientPhone     String?   @map("client_phone")
  clientDocNumber String?   @map("client_doc_number") // nro. de documento opcional
  clientCountry   String?   @map("client_country") // país del cliente (VikRentCar orders.country, ~24%)
  licenseExpiry   DateTime? @map("license_expiry") // vencimiento licencia de conducir

  // Conductores adicionales autorizados (además del titular). Array JSON
  // [{ name }]; sus fotos de licencia se guardan como RentalDocument con
  // holderName. Los nombres figuran en el acta como conductores autorizados.
  additionalDrivers Json? @map("additional_drivers")

  startAt DateTime @map("start_at") // fecha/hora de retiro (UTC)
  endAt   DateTime @map("end_at") // fecha/hora de devolución (UTC)

  // Condiciones económicas del contrato (registro, sin cobro). Ver ContractPricing.
  pricing Json? @map("pricing")

  // Datos económicos importados de VikRentCar (referencia; el empleado los usa
  // para precargar/confirmar las condiciones). Ver docs/wordpress-mapping.md:
  // `days` 100%, `custdata` 100% (texto libre), `order_total` ~95%, `car_cost` ~24%.
  bookingDays        Int?     @map("booking_days") // days de la orden
  bookingPricePerDay Decimal? @map("booking_price_per_day") @db.Decimal(12, 2) // car_cost/days (si viene)
  bookingTotal       Decimal? @map("booking_total") @db.Decimal(12, 2) // order_total (con extras)
  bookingPaid        Decimal? @map("booking_paid") @db.Decimal(12, 2) // totpaid: pagado/anticipo de la reserva (precarga "Seña")
  bookingNote        String?  @map("booking_note") @db.Text // custdata: info de la reserva (staff)
  // Modelo de VikRentCar (cars.name vía idcar): se muestra cuando la reserva
  // llegó sin unidad física asignada (carindex NULL).
  bookingModel       String?  @map("booking_model")
  bookingPickupPlace String?  @map("booking_pickup_place") // idplace → places.name
  bookingReturnPlace String?  @map("booking_return_place") // idreturnplace → places.name
  // Opcionales de VikRentCar (wp_vikrentcar_optionals). Los packs de km → accesorios
  // (descripción + importe precalculado); la "Mejora de Seguro" → flag que baja la
  // franquicia. Precargan las condiciones; el sync nunca pisa `pricing`.
  bookingAccessories       String?  @map("booking_accessories") @db.Text
  bookingAccessoriesAmount Decimal? @map("booking_accessories_amount") @db.Decimal(12, 2)
  bookingInsuranceUpgrade  Boolean  @default(false) @map("booking_insurance_upgrade")

  // ¿La reserva está confirmada en VikRentCar? Las `standby` entran sin confirmar
  // (bookingConfirmed=false) y se marcan en naranja; el sync la pasa a true si el
  // dueño la confirma. Los alquileres manuales nacen confirmados (default true).
  bookingConfirmed Boolean @default(true) @map("booking_confirmed")

  origin      RentalOrigin @default(manual)
  wpBookingId Int?         @unique @map("wp_booking_id") // id de la orden VikRentCar
  language    Language     @default(es)
  status      RentalStatus @default(reserved)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  inspections       Inspection[]
  documents         RentalDocument[]
  signatureRequests SignatureRequest[]

  @@index([status])
  @@index([startAt])
  @@index([endAt]) // devoluciones de hoy / vencidas (dashboard)
  @@index([origin]) // conteos y filtros del sync
  @@index([vehicleId]) // alquileres por vehículo, reservas sin unidad
  @@map("rentals")
}

// ---------------------------------------------------------------------------
// Documentos del cliente (licencia/DNI/pasaporte) — SOLO INTERNO
// ---------------------------------------------------------------------------
//
// Capturados opcionalmente en la entrega. Dato sensible: se guardan en R2
// (bucket privado) y se sirven únicamente por /api/media con sesión. NO se
// embeben en el acta ni se envían por email. Varias filas por alquiler
// (frente/dorso, etc.).
model RentalDocument {
  id String @id @default(cuid())

  rentalId String @map("rental_id")
  rental   Rental @relation(fields: [rentalId], references: [id])

  kind DocumentKind
  url  String // clave en R2 (bucket privado)

  // Nombre del titular del documento cuando pertenece a un conductor adicional
  // (no al cliente principal). Null = documento del titular del alquiler.
  holderName String? @map("holder_name")

  // Empleado que lo cargó (auditoría). Nullable por robustez.
  uploadedById String? @map("uploaded_by_id")
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  capturedAt DateTime @default(now()) @map("captured_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([rentalId])
  @@map("rental_documents")
}

// ---------------------------------------------------------------------------
// Firma remota (el cliente firma en su propio teléfono escaneando un QR)
// ---------------------------------------------------------------------------
//
// El empleado, en el paso "Firma" del wizard, genera un pedido y muestra un QR
// en su pantalla. El cliente lo escanea, abre la página pública /sign/[id] (sin
// sesión, id no adivinable, con expiración y de un solo uso), ve el resumen y
// firma. El wizard poolea el estado y, al detectar `signed`, toma la firma.
model SignatureRequest {
  id String @id @default(cuid())

  // Borrador del wizard: la firma se guarda bajo la misma clave que espera el
  // guardado (uploads/{draftId}/signature.png).
  draftId String @map("draft_id")

  rentalId String @map("rental_id")
  rental   Rental @relation(fields: [rentalId], references: [id])

  type     InspectionType
  language Language       @default(es)

  // Snapshot del resumen para mostrarle al cliente qué está firmando.
  summary Json?

  signerName   String?                @map("signer_name")
  signatureKey String?                @map("signature_key")
  status       SignatureRequestStatus @default(pending)

  createdById String? @map("created_by_id")
  createdBy   User?   @relation(fields: [createdById], references: [id])

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([rentalId])
  @@map("signature_requests")
}

// ---------------------------------------------------------------------------
// Inspecciones (entrega / devolución) — INMUTABLES una vez firmadas
// ---------------------------------------------------------------------------

model Inspection {
  id   String         @id @default(cuid())
  type InspectionType

  rentalId String @map("rental_id")
  rental   Rental @relation(fields: [rentalId], references: [id])

  vehicleId String  @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  // Empleado que la realizó (auditoría).
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  km        Int
  fuelLevel Int @map("fuel_level") // octavos de tanque, 0–8

  // Respuestas del checklist configurable, como JSON { itemId: value }.
  checklistResponses Json?   @map("checklist_responses")
  observations       String?

  signatureUrl String? @map("signature_url") // firma del cliente (R2)
  signerName   String? @map("signer_name")

  // Liquidación de la devolución (solo en return_): excedente de km, nafta
  // faltante y cargos por daño nuevo contra el depósito. Ver src/lib/settlement.
  // Inmutable: es parte de lo que el cliente firma. Sin cobro.
  settlement Json? @map("settlement")

  // Geolocalización opcional (si el dispositivo dio permiso).
  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now()) @map("created_at")

  media   InspectionMedia[]
  damages Damage[]

  @@index([rentalId])
  @@index([vehicleId])
  @@map("inspections")
}

model InspectionMedia {
  id String @id @default(cuid())

  inspectionId String     @map("inspection_id")
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  type       MediaType
  url        String
  capturedAt DateTime  @map("captured_at") // fecha/hora de captura

  createdAt DateTime @default(now()) @map("created_at")

  @@index([inspectionId])
  @@map("inspection_media")
}

// ---------------------------------------------------------------------------
// Daños (sobre el croquis del vehículo)
// ---------------------------------------------------------------------------

model Damage {
  id String @id @default(cuid())

  vehicleId String  @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  // Inspección donde se detectó. Nullable: los daños migrados en el seed
  // inicial no provienen de una inspección de Andes.
  inspectionId String?     @map("inspection_id")
  inspection   Inspection? @relation(fields: [inspectionId], references: [id])

  view        DamageView @default(top)
  posX        Float      @map("pos_x") // posición en el croquis (0–1)
  posY        Float      @map("pos_y")
  description String?
  photoUrl    String?    @map("photo_url")
  repaired    Boolean    @default(false)

  // Auditoría: quién cargó el daño (createdAt = fecha de carga) y, si se reparó,
  // quién lo marcó reparado y cuándo. Nullable por robustez (daños del seed).
  reportedById String? @map("reported_by_id")
  reportedBy   User?   @relation("DamageReporter", fields: [reportedById], references: [id])
  repairedById String? @map("repaired_by_id")
  repairedBy   User?   @relation("DamageRepairer", fields: [repairedById], references: [id])
  repairedAt   DateTime? @map("repaired_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([vehicleId])
  @@index([inspectionId])
  @@map("damages")
}

// ---------------------------------------------------------------------------
// Mantenimiento
// ---------------------------------------------------------------------------

model MaintenanceLog {
  id String @id @default(cuid())

  vehicleId String  @map("vehicle_id")
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  type        MaintenanceType
  date        DateTime
  km          Int?
  cost        Decimal?        @db.Decimal(12, 2)
  place       String? // taller / lugar donde se hizo el service o arreglo
  description String

  createdAt DateTime @default(now()) @map("created_at")

  @@index([vehicleId])
  @@map("maintenance_logs")
}

// ---------------------------------------------------------------------------
// Configuración del checklist
// ---------------------------------------------------------------------------

model ChecklistItem {
  id       String  @id @default(cuid())
  label    String // etiqueta mostrada al empleado (español)
  ordering Int     @default(0)
  active   Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("checklist_items")
}

// ---------------------------------------------------------------------------
// Condiciones económicas precargadas (plantilla global, un solo registro)
// ---------------------------------------------------------------------------
//
// Valores por defecto que el empleado ve precargados en el paso "Condiciones"
// de la entrega y puede ajustar antes de firmar. Singleton: siempre id = 1.
// La "hora extra" se expresa como % de la tarifa diaria del alquiler.
model ConditionSettings {
  id               Int      @id @default(1)
  insuranceAmount  Decimal? @map("insurance_amount") @db.Decimal(12, 2) // seguro
  kmPerDay         Int?     @map("km_per_day") // km incluidos por día
  extraKmRate      Decimal? @map("extra_km_rate") @db.Decimal(12, 2) // $ por km extra
  extraHourPercent Int?     @map("extra_hour_percent") // % de la tarifa diaria por hora extra
  // Franquicia (deducible del seguro): la estándar y la reducida cuando el
  // alquiler lleva "Mejora de Seguro" (ej. 600.000 → 400.000).
  deductible        Decimal? @map("deductible") @db.Decimal(12, 2) // franquicia estándar
  deductibleReduced Decimal? @map("deductible_reduced") @db.Decimal(12, 2) // franquicia con mejora de seguro
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("condition_settings")
}

// Textos editables de los correos transaccionales y casilla remitente.
// Singleton: siempre id = 1. Cada campo es un override opcional del diccionario
// i18n (src/lib/i18n/dictionaries.ts): si está vacío/null, se usa el texto por
// defecto del sistema. `fromAddress` pisa la env var EMAIL_FROM.
model EmailSettings {
  id          Int     @id @default(1)
  fromAddress String? @map("from_address") // casilla "desde" (pisa EMAIL_FROM)

  // Español
  esHandoverSubject String? @map("es_handover_subject")
  esReturnSubject   String? @map("es_return_subject")
  esGreeting        String? @map("es_greeting")
  esHandoverBody    String? @map("es_handover_body")
  esReturnBody      String? @map("es_return_body")
  esAttachmentNote  String? @map("es_attachment_note")
  esRegards         String? @map("es_regards")

  // Inglés
  enHandoverSubject String? @map("en_handover_subject")
  enReturnSubject   String? @map("en_return_subject")
  enGreeting        String? @map("en_greeting")
  enHandoverBody    String? @map("en_handover_body")
  enReturnBody      String? @map("en_return_body")
  enAttachmentNote  String? @map("en_attachment_note")
  enRegards         String? @map("en_regards")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_settings")
}

// ---------------------------------------------------------------------------
// Log de sincronización con VikRentCar
// ---------------------------------------------------------------------------

model SyncLog {
  id        String     @id @default(cuid())
  result    SyncResult
  imported  Int        @default(0)
  updated   Int        @default(0)
  errors    Int        @default(0)
  message   String?
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("sync_logs")
}
